# Addon Metadata
msgctxt "#30000"
msgid "My Collections"
msgstr "मेरे संग्रह"

msgctxt "#30001"
msgid "Manage custom movie collections."
msgstr "कस्टम मूवी संग्रह प्रबंधित करें।"

msgctxt "#30002"
msgid "Manual movie collection manager using JSON storage."
msgstr "JSON स्टोरेज का उपयोग करके मैन्युअल मूवी संग्रह प्रबंधक।"

# Context Menu & Buttons
msgctxt "#30003"
msgid "Add to My Collection"
msgstr "मेरे संग्रह में जोड़ें"

msgctxt "#30004"
msgid "Search Movies in Library"
msgstr "# लाइब्रेरी में मूवी खोजें"

msgctxt "#30005"
msgid "Add New Collection"
msgstr "+ नया संग्रह जोड़ें"

msgctxt "#30006"
msgid "Import Collection"
msgstr "* संग्रह आयात करें"

# Collection Context Menu
msgctxt "#30007"
msgid "Rename Collection"
msgstr "संग्रह का नाम बदलें"

msgctxt "#30008"
msgid "Choose Custom Poster"
msgstr "कस्टम पोस्टर चुनें"

msgctxt "#30009"
msgid "Revert to Default Poster"
msgstr "डिफ़ॉल्ट पोस्टर पर वापस जाएं"

msgctxt "#30010"
msgid "Export Collection"
msgstr "संग्रह निर्यात करें"

msgctxt "#30011"
msgid "Delete Collection"
msgstr "संग्रह हटाएं"

msgctxt "#30012"
msgid "Rescan Movie Collection"
msgstr "मूवी संग्रह को फिर से स्कैन करें"

# Item Context Menu
msgctxt "#30013"
msgid "Move Position"
msgstr "स्थान बदलें"

msgctxt "#30014"
msgid "Remove from Collection"
msgstr "संग्रह से निकालें"

msgctxt "#30015"
msgid "Rescan for Movie"
msgstr "मूवी के लिए फिर से स्कैन करें"

# Dialogs & Notifications
msgctxt "#30016"
msgid "Success"
msgstr "सफलता"

msgctxt "#30017"
msgid "Failed"
msgstr "विफल"

msgctxt "#30018"
msgid "Missing"
msgstr "लापता"

msgctxt "#30019"
msgid "Overwrite?"
msgstr "पुराने को बदलें?"

msgctxt "#30020"
msgid "Confirm"
msgstr "पुष्टि करें"

msgctxt "#30021"
msgid "Already in collection"
msgstr "पहले से ही संग्रह में है"

msgctxt "#30022"
msgid "Position"
msgstr "स्थान"

msgctxt "#30023"
msgid "Create a collection first."
msgstr "पहले एक संग्रह बनाएं।"

msgctxt "#30024"
msgid "No new movies found."
msgstr "कोई नई मूवी नहीं मिली।"

msgctxt "#30025"
msgid "Exported"
msgstr "निर्यात किया गया"

msgctxt "#30026"
msgid "NOT IN LIBRARY"
msgstr "लाइब्रेरी में नहीं है"

msgctxt "#30027"
msgid "This movie is missing from your local database."
msgstr "यह मूवी आपके स्थानीय डेटाबेस में नहीं है।"