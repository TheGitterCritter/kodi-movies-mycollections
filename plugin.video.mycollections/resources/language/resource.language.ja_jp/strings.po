# Addon Metadata
msgctxt "#30000"
msgid "My Collections"
msgstr "マイコレクション"

msgctxt "#30001"
msgid "Manage custom movie collections."
msgstr "カスタム映画コレクションを管理します。"

msgctxt "#30002"
msgid "Manual movie collection manager using JSON storage."
msgstr "JSONストレージを使用した手動の映画コレクションマネージャー。"

# Context Menu & Buttons
msgctxt "#30003"
msgid "Add to My Collection"
msgstr "マイコレクションに追加"

msgctxt "#30004"
msgid "Search Movies in Library"
msgstr "# ライブラリ内の映画を検索"

msgctxt "#30005"
msgid "Add New Collection"
msgstr "+ 新しいコレクションを追加"

msgctxt "#30006"
msgid "Import Collection"
