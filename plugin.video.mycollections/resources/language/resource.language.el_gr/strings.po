msgid "No new movies found."
msgstr "Δεν βρέθηκαν νέες ταινίες."

msgctxt "#30025"
msgid "Exported"
msgstr "Εξήχθη"

msgctxt "#30026"
msgid "NOT IN LIBRARY"
