msgctxt "#30013"
msgid "Move Position"
msgstr "위치 이동"

msgctxt "#30014"
msgid "Remove from Collection"
msgstr "컬렉션에서 제거"

msgctxt "#30015"
msgid "Rescan for Movie"
msgstr "영화 다시 검색"

# Dialogs & Notifications
msgctxt "#30016"
msgid "Success"
msgstr "성공"

msgctxt "#30017"
msgid "Failed"
msgstr "실패"

msgctxt "#30018"
