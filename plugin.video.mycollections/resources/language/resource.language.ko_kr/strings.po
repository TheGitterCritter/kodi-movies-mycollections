# Addon Metadata
msgctxt "#30000"
msgid "My Collections"
msgstr "내 컬렉션"

msgctxt "#30001"
msgid "Manage custom movie collections."
msgstr "사용자 지정 영화 컬렉션을 관리합니다."

msgctxt "#30002"
msgid "Manual movie collection manager using JSON storage."
msgstr "JSON 스토리지를 사용하는 수동 영화 컬렉션 관리자."

# Context Menu & Buttons
msgctxt "#30003"
msgid "Add to My Collection"
msgstr "내 컬렉션에 추가"

msgctxt "#30004"
msgid "Search Movies in Library"
msgstr "# 라이브러리에서 영화 검색"

msgctxt "#30005"
msgid "Add New Collection"
msgstr "+ 새 컬렉션 추가"

msgctxt "#30006"
msgid "Import Collection"
msgstr "* 컬렉션 가져오기"

# Collection Context Menu
msgctxt "#30007"
msgid "Rename Collection"
msgstr "컬렉션 이름 변경"

msgctxt "#30008"
msgid "Choose Custom Poster"
msgstr "사용자 지정 포스터 선택"

msgctxt "#30009"
