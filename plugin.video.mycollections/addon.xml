<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.mycollections" name="My Collections" version="1.0.0" provider-name="TheGitterCritter">
    <requires>
        <import addon="xbmc.python" version="1.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>

    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="context_entry.py">
                <label>$ADDON[plugin.video.mycollections 30003]</label>
                <visible>[String.Contains(Container.FolderPath,mode=search_results) | !String.Contains(Container.FolderPath,plugin.video.mycollections)] + [String.IsEqual(ListItem.dbtype,movie) | !String.IsEmpty(ListItem.DBID)]</visible>
            </item>
        </menu>
    </extension>

